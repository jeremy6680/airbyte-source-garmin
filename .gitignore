# =============================================================================
# CREDENTIALS & SECRETS — NEVER COMMIT
# =============================================================================
secrets/
.env
.env.local
*.pem
*.key

# Garmin session token (contains serialised OAuth tokens)
garmin_session.json
*.session.json

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
MANIFEST

# Virtual environment
venv/
.venv/
env/

# Tests & coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# =============================================================================
# AIRBYTE SPECIFIC
# =============================================================================
# Local config files containing real credentials
secrets/config.json
secrets/catalog.json

# Output of `read` commands (may contain personal health data)
output/
*.jsonl

# Airbyte local cache
.airbyte/

# =============================================================================
# DOCKER
# =============================================================================
# Locally built images
*.tar

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
*~

# =============================================================================
# IDE
# =============================================================================
.vscode/
.idea/
*.swp

# =============================================================================
# LOGS
# =============================================================================
*.log
logs/

# =============================================================================
# EXCEPTIONS — KEEP THESE FILES
# =============================================================================
# The secrets directory must exist but stay empty (except .gitkeep)
!secrets/.gitkeep

# Test fixtures are fake data — safe to commit
!unit_tests/fixtures/
!integration_tests/sample_files/
